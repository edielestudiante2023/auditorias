#--------------------------------------------------------------------
# CONFIGURACION DEL AMBIENTE
#--------------------------------------------------------------------
# Copiar este archivo como .env y ajustar los valores
# NUNCA commitear el archivo .env con valores reales
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

# URL base de la aplicacion (ajustar segun ambiente)
app.baseURL = 'http://localhost/auditorias/public/'
app.appTimezone = America/Bogota

# Forzar HTTPS (activar en produccion)
# app.forceGlobalSecureRequests = true

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

# Base de datos principal
database.default.hostname = 127.0.0.1
database.default.database = cycloid_auditorias
database.default.username =
database.default.password =
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

# Para conexion SSL (DigitalOcean Managed DB en produccion)
# database.default.hostname = tu-host-digitalocean.db.ondigitalocean.com
# database.default.port = 25060

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------

# Generar con: php spark key:generate
# encryption.key =

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

# session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
# session.savePath = null

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------

# Nivel de log: 3 = errores, 4 = todos
# logger.threshold = 4

#--------------------------------------------------------------------
# EMAIL - SENDGRID
#--------------------------------------------------------------------

# Remitente de notificaciones
email.fromEmail = ''
email.fromName = 'Cycloid Talent - Auditorias'

# API Key de SendGrid (obtener en sendgrid.com)
sendgrid.apiKey = ''

#--------------------------------------------------------------------
# TUTORIAL VIDEO
#--------------------------------------------------------------------

# URL del video tutorial para proveedores
tutorial.videoUrl = 'https://www.youtube.com/'
